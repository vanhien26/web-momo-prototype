{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "node-devserver",
      "runtimeExecutable": "node",
      "runtimeArgs": [".devserver.js"],
      "port": 3000
    },
    {
      "name": "python-devserver",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["scripts/serve-local.py", "--port", "4321"],
      "port": 4321
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "4322", "."],
      "port": 4322
    }
  ]
}
